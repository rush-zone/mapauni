generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model University {
  id            String           @id @default(cuid())
  slug          String           @unique
  name          String
  cnpj          String?          @unique
  mecCode       String?          @unique
  type          UniversityType
  category      String?
  logoUrl       String?
  coverUrl      String?
  description   String?
  website       String?
  phone         String?
  whatsapp      String?
  email         String?
  plan          PlanType         @default(PREMIUM)
  address       String?
  city          String
  state         String
  zipCode       String?
  lat           Float?
  lng           Float?
  instagram     String?
  facebook      String?
  linkedin      String?
  youtube       String?
  tiktok        String?
  igc           Float?
  ci            Float?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  foundedYear   Int?
  galleryImages String[]
  sigla         String?
  academicOrg   String?
  ibgeCode      String?
  isActive      Boolean          @default(true)
  courses              Course[]
  leads                Lead[]
  reviews              Review[]
  users                UniversityUser[]
  acervoAcademico      AcervoAcademico?
  atosRegulatorios     AtoRegulatorio[]
  processosEmec        ProcessoEmec[]
  ocorrenciasEmec      OcorrenciaEmec[]
  cursosAutorizados    CursoAutorizadoEmec[]
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
}

// ── e-MEC scraped data ────────────────────────────────────────────────────────

model AcervoAcademico {
  id                    String      @id @default(cuid())
  universityId          String      @unique
  university            University  @relation(fields: [universityId], references: [id])

  // Responsável pelo acervo
  instituicaoResponsavel String?
  endereco               String?
  municipio              String?
  uf                     String?
  email                  String?
  telefone               String?
  responsavelLegal       String?

  // Acervo digital
  tipoAcervo            String?   // "Digital", "Físico", "Híbrido"
  diplomaDigital        Boolean?
  urlDiplomaDigital     String?
  urlHistoricoDigital   String?
  registroDiploma       String?   // "Próprio", "Terceirizado"

  emecSyncedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model AtoRegulatorio {
  id             String     @id @default(cuid())
  universityId   String
  university     University @relation(fields: [universityId], references: [id])

  tipo           String     // "Credenciamento", "Recredenciamento", "Autorização"
  numero         String?
  dataPublicacao DateTime?
  situacao       String?
  arquivo        String?    // URL do DOU/PDF se disponível

  emecSyncedAt   DateTime?
  createdAt      DateTime   @default(now())
}

model ProcessoEmec {
  id             String     @id @default(cuid())
  universityId   String
  university     University @relation(fields: [universityId], references: [id])

  numero         String
  tipo           String?
  situacao       String?
  dataAutuacao   DateTime?
  dataDecisao    DateTime?
  resultado      String?

  emecSyncedAt   DateTime?
  createdAt      DateTime   @default(now())
}

model OcorrenciaEmec {
  id             String     @id @default(cuid())
  universityId   String
  university     University @relation(fields: [universityId], references: [id])

  tipo           String?
  descricao      String?
  dataOcorrencia DateTime?
  situacao       String?

  emecSyncedAt   DateTime?
  createdAt      DateTime   @default(now())
}

model CursoAutorizadoEmec {
  id             String     @id @default(cuid())
  universityId   String
  university     University @relation(fields: [universityId], references: [id])

  codigoEmec     String?
  nome           String
  grau           String?    // "Bacharelado", "Licenciatura", "Tecnológico", "Especialização"
  modalidade     String?    // "Presencial", "EaD"
  municipio      String?
  uf             String?
  situacao       String?    // "Em Atividade", "Extinto"
  conceito       Float?     // CPC/ENADE
  vagas          Int?

  emecSyncedAt   DateTime?
  createdAt      DateTime   @default(now())
}

model Review {
  id            String       @id @default(cuid())
  rating        Int
  comment       String?
  status        ReviewStatus @default(PENDING)
  verifiedAt    DateTime?
  verifyMethod  String?
  universityId  String
  authorName    String
  authorEmail   String
  courseStudied String?
  replyText     String?
  repliedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  university    University   @relation(fields: [universityId], references: [id])
}

model Course {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  mecCode      String?
  area         String
  subArea      String?
  degree       DegreeType
  modality     ModalityType
  shift        ShiftType[]
  duration     Int
  priceMonthly Float?
  enade        Float?
  ccpValue     Float?
  active       Boolean      @default(true)
  description  String?
  universityId String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  university   University   @relation(fields: [universityId], references: [id])
  leads        Lead[]
  offers       Offer[]
}

model Offer {
  id           String    @id @default(cuid())
  courseId     String
  semester     String
  vacancies    Int
  enrolled     Int       @default(0)
  priceMonthly Float?
  prouni       Boolean   @default(false)
  fies         Boolean   @default(false)
  cutoffScore  Float?
  enrollStart  DateTime?
  enrollEnd    DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  course       Course    @relation(fields: [courseId], references: [id])
}

model Lead {
  id           String     @id @default(cuid())
  name         String
  email        String
  phone        String
  message      String?
  source       String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  status       LeadStatus @default(NEW)
  openedAt     DateTime?
  universityId String
  courseId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  course       Course?    @relation(fields: [courseId], references: [id])
  university   University @relation(fields: [universityId], references: [id])
}

model UniversityUser {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(MANAGER)
  universityId String
  createdAt    DateTime   @default(now())
  university   University @relation(fields: [universityId], references: [id])
}

enum UniversityType {
  FEDERAL
  ESTADUAL
  MUNICIPAL
  PRIVADA
}

enum PlanType {
  PREMIUM
  PRO
}

enum DegreeType {
  BACHARELADO
  LICENCIATURA
  TECNOLOGO
  POS_GRADUACAO
  MBA
  MESTRADO
  DOUTORADO
}

enum ModalityType {
  PRESENCIAL
  EAD
  HIBRIDO
}

enum ShiftType {
  MANHA
  TARDE
  NOITE
  INTEGRAL
}

enum LeadStatus {
  NEW
  OPENED
  CONTACTED
  ENROLLED
  LOST
}

enum UserRole {
  OWNER
  MANAGER
  VIEWER
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
